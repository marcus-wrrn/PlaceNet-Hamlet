# MQTT Broker & Client
MQTT_PORT=1883
MQTT_CLIENT_ID=placenet-home

# MQTT Authentication (always required)
MQTT_USERNAME=placenet
MQTT_PASSWORD=changeme

# MQTTS (MQTT over TLS)
# Set MQTT_TLS_ENABLED=true to use TLS. The plain MQTT listener will be
# disabled and all traffic routed through the MQTTS listener on MQTTS_PORT.
MQTT_TLS_ENABLED=false
MQTTS_PORT=8883
# Paths are relative to PLACENET_CONFIG_DIR.
# Path to the CA certificate used to sign the broker cert.
MQTT_CAFILE=certs/ca.crt
# Broker certificate and private key (only needed by the broker).
MQTT_CERTFILE=certs/broker.crt
MQTT_KEYFILE=certs/broker.key

# Broker TLS certificate SANs
# By default, all non-loopback local IPs are auto-detected and embedded as IP
# SANs in the broker TLS cert. On networks with DHCP, set BROKER_SAN_IPS to a
# stable IP (or comma-separated list) so the cert isn't invalidated by address
# changes. If unset, auto-detection is used.
BROKER_SAN_IPS=192.168.1.50
# Additional DNS hostnames to include alongside "localhost" (always present).
# Comma-separated. Useful for mDNS names or stable hostnames on the LAN.
BROKER_SAN_HOSTNAMES=placenet-home.local,myserver.local

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
# Set to false to disable TLS on the HTTP server (plain HTTP). Default: true.
HTTP_TLS_ENABLED=true

# Config directory for generated files (e.g. mosquitto.conf, passwd)
PLACENET_CONFIG_DIR=config

# Development Setting
USE_NETWORK_JITTER=true # Used to set broadcast staggering for beacons (prevents LoRa packet collisions while increasing broadcast time)
# Measured in seconds
BROADCAST_INTERVAL=30 # Interval for broadcast default 30

# Broadcast key management
# How long (seconds) each AES-128 key remains active before rotating.
# A new key is generated at the next broadcast cycle after this elapses.
# Default: 3600 (1 hour). For testing, use a smaller value (e.g. 120).
KEY_ROTATION_INTERVAL=3600
# How long (seconds) a retired key is kept in the DB after rotation.
# Must be > KEY_ROTATION_INTERVAL so beacons that miss one broadcast cycle
# can still verify messages with the previous key. Default: 7200 (2 hours).
KEY_EXPIRY=7200

# Cloud gateway registration
# This server's URL is used as its identity when registering with the gateway.
# Does not need to be internet-routable; treated as an opaque ID. TODO: change to a proper ID system
PLACENET_SERVER_URL=http://localhost:8080
# URL of the cloud gateway WebSocket endpoint (must be internet-accessible).
# Leave unset to disable cloud gateway registration.
PLACENET_GATEWAY_URL=ws://gateway.example.com:9000
